{
  "name": "@betterbase/examples-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utilities for Betterbase example apps",
  "license": "Apache-2.0",
  "author": "Betterbase <hello@betterbase.dev>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external @mantine/core --external @mantine/hooks --external @betterbase/sdk --external lucide-react",
    "dev": "tsup src/index.ts --format esm --dts --external react --external @mantine/core --external @mantine/hooks --external @betterbase/sdk --external lucide-react --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "check": "prettier --write . && pnpm build && pnpm typecheck"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "@mantine/core": "^7.17.0",
    "@mantine/hooks": "^7.17.0"
  },
  "dependencies": {
    "@betterbase/sdk": "link:../../betterbase/js",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "@mantine/core": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
